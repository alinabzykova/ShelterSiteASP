@{
    ViewData["Title"] = "Главная";
}

<div class="min-h-screen">

    <section class="bg-red-500 rounded-[40px] p-10 lg:p-20 overflow-hidden relative">

        <div class="flex flex-col lg:flex-row gap-10 relative z-10">

            <!-- Левая часть с текстом -->
            <div class="flex-1">
                <h1 class="text-5xl lg:text-7xl font-bold text-white leading-tight">
                    Спасённый хвост 🐾
                </h1>
                <p class="text-xl text-red-100 mt-6 leading-relaxed">
                    Мы помогаем бездомным животным найти
                    любящую семью и настоящий дом.
                </p>
                <div class="flex gap-6 mt-8">
                    <div>
                        <div class="text-3xl font-bold text-white">150+</div>
                        <div class="text-red-200 text-sm">животных спасено</div>
                    </div>
                    <div>
                        <div class="text-3xl font-bold text-white">50+</div>
                        <div class="text-red-200 text-sm">нашли дом</div>
                    </div>
                    <div>
                        <div class="text-3xl font-bold text-white">30+</div>
                        <div class="text-red-200 text-sm">волонтёров</div>
                    </div>
                </div>
                <div class="mt-8 flex gap-4">
                    <a asp-controller="Animal"
                       asp-action="Index"
                       class="bg-red-800 hover:bg-red-900 text-white px-8 py-4 rounded-2xl text-lg transition">
                        Смотреть животных
                    </a>
                    <a asp-controller="Account"
                       asp-action="Register"
                       class="bg-white hover:bg-red-100 text-red-600 px-8 py-4 rounded-2xl text-lg transition">
                        Зарегистрироваться
                    </a>
                </div>
            </div>

            <div class="flex-1">
                <img src="/images/dog.png"
                     class="w-full object-contain relative top-20 lg:top-42 xl:top-18"
                     alt="Собака">
            </div>

        </div>

    </section>

    <section class="grid grid-cols-1 md:grid-cols-3 gap-6 mt-12">

        <div class="bg-white rounded-[30px] p-8 shadow">

            <div class="text-5xl mb-4">🏠</div>

            <h2 class="text-2xl font-bold mb-3">
                Новый дом
            </h2>

            <p class="text-gray-600">
                Помогаем животным найти заботливых хозяев.
            </p>

        </div>

        <div class="bg-white rounded-[30px] p-8 shadow">

            <div class="text-5xl mb-4">❤️</div>

            <h2 class="text-2xl font-bold mb-3">
                Забота
            </h2>

            <p class="text-gray-600">
                Все животные получают помощь и уход.
            </p>

        </div>

        <div class="bg-white rounded-[30px] p-8 shadow">

            <div class="text-5xl mb-4">🐶</div>

            <h2 class="text-2xl font-bold mb-3">
                Друзья
            </h2>

            <p class="text-gray-600">
                У каждого питомца своя история и характер.
            </p>

        </div>

    </section>

    <section class="mt-16">

        <h2 class="text-4xl font-bold text-center mb-10">
            Наши питомцы
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

            <div class="bg-white rounded-[30px] shadow overflow-hidden">

                <img src="/images/dogs/Бобик 1.jpg"
                     class="w-full h-64 object-cover">

                <div class="p-6">

                    <h3 class="text-2xl font-bold">
                        Бобик
                    </h3>

                    <p class="text-gray-500 mt-2">
                        Добрый и весёлый лабрадор.
                    </p>

                </div>

            </div>

            <div class="bg-white rounded-[30px] shadow overflow-hidden">

                <img src="/images/dogs/Тузик 1.jpg"
                     class="w-full h-64 object-cover">

                <div class="p-6">

                    <h3 class="text-2xl font-bold">
                        Тузик
                    </h3>

                    <p class="text-gray-500 mt-2">
                        Активный и дружелюбный корги.
                    </p>

                </div>

            </div>

            <div class="bg-white rounded-[30px] shadow overflow-hidden">

                <img src="/images/dogs/Лайка 1.jpg"
                     class="w-full h-64 object-cover">

                <div class="p-6">

                    <h3 class="text-2xl font-bold">
                        Лайка
                    </h3>

                    <p class="text-gray-500 mt-2">
                        Спокойная и умная овчарка.
                    </p>

                </div>

            </div>

        </div>

    </section>

</div>