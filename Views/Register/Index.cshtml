@model RegisterViewModel
@{
    Layout = null;
    ViewData["Title"] = "Регистрация";
}

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Регистрация — Приют для животных</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="m-0 p-0 h-screen overflow-hidden flex flex-col">

    <nav class="bg-[#E5E7EB] px-8 py-3 flex items-center justify-between shrink-0">
        <div class="flex items-center gap-2">
            <span class="text-red-500 text-lg">🐾</span>
            <span class="text-[#C8433B] text-base font-semibold">Спасённый Хвост</span>
        </div>
        <div class="flex items-center gap-6 text-sm">
            <a asp-controller="Home" asp-action="Index" class="text-[#666] hover:text-red-500">Главная</a>
            <a asp-controller="Animal" asp-action="Index" class="text-[#666] hover:text-red-500">Каталог</a>
            <a asp-controller="Profile" asp-action="Index" class="text-[#666] hover:text-red-500">Профиль</a>
            <a asp-controller="Register" asp-action="Index" class="text-red-500 font-semibold">Регистрация</a>
        </div>
    </nav>

    <div class="flex flex-1">

        <div class="w-[40%] bg-[#C82626] flex flex-col items-center justify-center relative overflow-hidden">

            <svg class="absolute top-0 left-0 w-full h-24" viewBox="0 0 400 100" preserveAspectRatio="none">
                <path d="M0,0 Q50,40 100,20 T200,30 T300,10 T400,0 L400,0 L0,0 Z" fill="rgba(255,255,255,0.06)" />
                <path d="M0,10 Q60,50 120,30 T240,35 T360,15 L400,10 L400,0 L0,0 Z" fill="rgba(255,255,255,0.04)" />
            </svg>

            <div class="absolute top-10 z-10">
                <img src="/images/paw.png" alt="" class="w-14 h-14 opacity-90" />
            </div>

            <div class="absolute top-24 left-0 w-full">
                <svg viewBox="0 0 400 60" class="w-full h-16" preserveAspectRatio="none">
                    <path d="M0,30 C40,10 60,50 100,30 C140,10 160,50 200,30 C240,10 260,50 300,30 C340,10 360,50 400,30" stroke="rgba(255,255,255,0.08)" stroke-width="2" fill="none" />
                    <path d="M0,40 C50,20 80,60 130,40 C180,20 210,60 260,40 C310,20 340,60 400,40" stroke="rgba(255,255,255,0.05)" stroke-width="1.5" fill="none" />
                </svg>
            </div>

            <div class="absolute top-28 left-4 w-20 h-20">
                <div class="w-2 h-2 bg-white/10 rounded-full absolute top-0 left-0"></div>
                <div class="w-2 h-2 bg-white/10 rounded-full absolute top-6 left-4"></div>
                <div class="w-2 h-2 bg-white/10 rounded-full absolute top-12 left-0"></div>
                <div class="w-2 h-2 bg-white/10 rounded-full absolute top-3 left-10"></div>
                <div class="w-2 h-2 bg-white/10 rounded-full absolute top-14 left-8"></div>
            </div>

            <div class="absolute top-28 right-6 w-16 h-16">
                <div class="w-2 h-2 bg-white/10 rounded-full absolute top-0 right-0"></div>
                <div class="w-2 h-2 bg-white/10 rounded-full absolute top-6 right-4"></div>
                <div class="w-2 h-2 bg-white/10 rounded-full absolute top-12 right-0"></div>
            </div>

            <div class="text-center mb-6 z-10">
                <p class="text-white/80 text-sm">Добро пожаловать в приют</p>
                <p class="text-white font-semibold text-lg">«Спасённый Хвост»</p>
            </div>

            <img src="/images/sobakus.png" alt="" class="w-[80%] max-w-[350px] object-contain z-10" />

            <svg class="absolute bottom-0 left-0 w-full h-32" viewBox="0 0 400 130" preserveAspectRatio="none">
                <path d="M0,130 Q60,70 120,100 T240,80 T360,110 L400,100 L400,130 Z" fill="rgba(255,255,255,0.06)" />
                <path d="M0,130 Q80,90 160,105 T320,95 L400,110 L400,130 Z" fill="rgba(255,255,255,0.04)" />
                <path d="M0,130 L0,120 Q100,85 200,110 T400,100 L400,130 Z" fill="rgba(255,255,255,0.03)" />
            </svg>

            <div class="absolute bottom-0 left-0 right-0 h-1 bg-[#520000]"></div>

        </div>

        <div class="w-[60%] bg-[#FFF7F3] flex items-center justify-center">

            <div class="w-full max-w-sm px-12">

                    <h1 class="text-[26px] font-bold text-[#2D2D2D] mb-2">Регистрация</h1>
                    <p class="text-[#8C8C8C] text-base mb-8">Создайте новый аккаунт</p>

                    <form asp-controller="Register" asp-action="Index" method="post" class="space-y-4">

                        <div>
                            <label class="block text-sm font-medium text-[#2D2D2D] mb-1">Имя</label>
                            <input asp-for="Name" type="text" required
                                   class="w-full px-4 py-[10px] rounded-lg border border-[#D9D9D9] bg-transparent text-[#2D2D2D] placeholder-[#B0B0B0] focus:outline-none focus:border-[#C82626] focus:ring-1 focus:ring-[#C82626]" />
                        </div>

                        <div>
                            <label class="block text-sm font-medium text-[#2D2D2D] mb-1">Email</label>
                            <input asp-for="Email" type="email" required
                                   class="w-full px-4 py-[10px] rounded-lg border border-[#D9D9D9] bg-transparent text-[#2D2D2D] placeholder-[#B0B0B0] focus:outline-none focus:border-[#C82626] focus:ring-1 focus:ring-[#C82626]" />
                        </div>

                        <div>
                            <label class="block text-sm font-medium text-[#2D2D2D] mb-1">Пароль</label>
                            <input asp-for="Password" type="password" required
                                   class="w-full px-4 py-[10px] rounded-lg border border-[#D9D9D9] bg-transparent text-[#2D2D2D] placeholder-[#B0B0B0] focus:outline-none focus:border-[#C82626] focus:ring-1 focus:ring-[#C82626]" />
                        </div>

                        <button type="submit"
                                class="w-full py-[10px] px-4 bg-[#C82626] hover:bg-[#A81E1E] text-white font-semibold rounded-lg transition-colors">
                            Зарегистрироваться
                        </button>

                    </form>

                    <p class="text-center mt-6 text-sm text-[#8C8C8C]">
                        Уже есть аккаунт?
                        <a asp-controller="Login" asp-action="Index" class="text-[#C82626] hover:underline font-medium">Войти</a>
                    </p>

                </div>

            </div>

    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/3.2.12/jquery.validate.unobtrusive.min.js"></script>

</body>
</html>
