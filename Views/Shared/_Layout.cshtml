<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Приют для животных</title>

    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100">

    <nav class="bg-gray-200 rounded-3xl m-4 p-6 flex justify-between items-center">

        <div class="text-2xl font-bold text-red-500">
            🐾 Спасённый Хвост
        </div>

        <div class="space-x-6 text-lg">
            <a asp-controller="Home" asp-action="Index" class="hover:text-red-500">Главная</a>
            <a asp-controller="Animal" asp-action="Index" class="hover:text-red-500">Каталог</a>
            <a asp-controller="Profile" asp-action="Index" class="hover:text-red-500">Профиль</a>
            <a asp-controller="Login" asp-action="Index" class="hover:text-red-500">Войти</a>
        </div>

    </nav>

    <div class="container mx-auto p-4">
        @RenderBody()
    </div> 
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/3.2.12/jquery.validate.unobtrusive.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
 
</body>
</html>