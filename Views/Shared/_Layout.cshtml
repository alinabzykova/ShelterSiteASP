<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Приют для животных</title>

    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100">

    <nav class="bg-[#E5E7EB] px-8 py-3 flex items-center justify-between">
        <div class="flex items-center gap-2">
            <span class="text-red-500 text-lg">🐾</span>
            <span class="text-[#C8433B] text-base font-semibold">Спасённый Хвост</span>
        </div>
        <div class="flex items-center gap-6 text-sm">
            <a asp-controller="Home" asp-action="Index" class="text-[#666] hover:text-red-500">Главная</a>
            <a asp-controller="Animal" asp-action="Index" class="text-[#666] hover:text-red-500">Каталог</a>
            <a asp-controller="Profile" asp-action="Index" class="text-[#666] hover:text-red-500">Профиль</a>
            <a asp-controller="Login" asp-action="Index" class="text-[#666] hover:text-red-500">Войти</a>
        </div>
    </nav>

    <div class="container mx-auto p-4">
        @RenderBody()
    </div> 
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/3.2.12/jquery.validate.unobtrusive.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
 
</body>
</html>