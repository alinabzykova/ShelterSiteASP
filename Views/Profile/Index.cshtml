@using ShelterSiteNET.Models
@model UserProfileViewModel
@{
    ViewData["Title"] = "Профиль пользователя";
}

<div class="min-h-screen bg-cover bg-center p-10" style="background-image: url('/images/shelterbg.png')">

    <div class="profile-itself max-w-[1200px] mx-auto rounded-[40px]">
         
        <div class="avatar bg-red-900 rounded-full justify-self-center self-center">
            <img src="/images/paw.png" alt="Аватар">
        </div>
         
        <div class="name rounded-[40px] p-2 flex flex-col justify-center">
            <div class="text-center lg:text-left">
                <h1 class="text-4xl lg:text-8xl font-bold text-white">
                    @Model.User.Login
                </h1>
                <h2 class="text-xl lg:text-2xl text-white mt-6 font-semibold">
                    ИЗБРАННОЕ
                </h2>
            </div>
        </div>
         
        <div class="info rounded-[40px]">
             
            <div class="description bg-white rounded-[40px] p-5 min-h-[300px]">
                <p>@Model.User.Description</p>
            </div>
             
            <div class="flex flex-col gap-4">

                @if (!Model.FavoriteAnimals.Any())
                {
                    <div class="bg-white rounded-[40px] p-5 text-center text-gray-400">
                        Нет избранных животных 😢
                        <a href="@Url.Action("Index", "Catalog")" class="block text-red-500 mt-2">
                            Перейти в каталог →
                        </a>
                    </div>
                }
                else
                {
                    @foreach (var animal in Model.FavoriteAnimals)
                    {
                        <div class="bg-white rounded-[40px] p-5 hover:bg-gray-50 transition cursor-pointer"
                             onclick="location.href='@Url.Action("Details", "Animals", new { id = animal.Id })'">
                            <div class="flex items-center gap-4">
                                <img src="@(animal.Images.Any() ? animal.Images[0] : "/images/paw.png")"
                                     class="w-12 h-12 rounded-full object-cover"
                                     alt="@animal.Name">
                                <div>
                                    <h3 class="font-bold text-lg">@animal.Name</h3>
                                    <p class="text-gray-500 text-sm">
                                        @GetAgeText(animal.Age) · @animal.Size
                                    </p>
                                </div>
                            </div>
                        </div>
                    }
                }

            </div>
        </div>

    </div>
</div>

@functions {
    string GetAgeText(int age)
    {
        if (age == 1) return age + " год";
        if (age >= 2 && age <= 4) return age + " года";
        return age + " лет";
    }
}

<style>
    .profile-itself {
        display: grid;
        grid-gap: 10px;
        grid-template-columns: 1fr 1fr;
        grid-template-rows: auto auto;
        padding: 10px;
    }

    .info {
        display: grid;
        grid-gap: 10px;
        grid-template-columns: 1fr 1fr;
        grid-column: span 2;
    }

    .avatar {
        width: 150px;
        height: 150px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .avatar img {
            width: 80%;
            height: 80%;
            object-fit: contain;
        }
</style>